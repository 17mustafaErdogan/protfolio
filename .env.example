# Supabase bağlantı bilgileri (örnek isimler — uygulama bunları doğrudan .env'den okumaz)
#
# Önerilen yöntem: config.json + dart-define-from-file
#   1. config.json.example dosyasını config.json olarak kopyalayın
#   2. config.json içindeki SUPABASE_URL ve SUPABASE_ANON_KEY değerlerini doldurun
#   3. Çalıştırma: flutter run --dart-define-from-file=config.json
#      (VS Code: .vscode/launch.json içinde aynı bayrak kullanılabilir)
#
# Alternatif (ek paket gerekmez): tek seferlik komut satırı
#   flutter run ^
#     --dart-define=SUPABASE_URL=https://your-project.supabase.co ^
#     --dart-define=SUPABASE_ANON_KEY=your_anon_key
#
# lib/config/env.dart değerleri String.fromEnvironment ile okur.
#
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
