# Supabase bağlantı bilgileri
#
# Önerilen yöntem: config.json kullanın
#   1. config.json.example dosyasını config.json olarak kopyalayın
#   2. config.json içindeki değerleri doldurun
#   3. config.json .gitignore'da olduğu için Git'e eklenmez
#
# Alternatif: .env dosyası (flutter_dotenv ile)
#   Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
